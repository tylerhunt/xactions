# Database path (SQLite file location)
DATABASE_PATH=/app/data/xactions.db

# Cloak encryption key (AES-256-GCM, base64-encoded 32 bytes)
# Generate with: :crypto.strong_rand_bytes(32) |> Base.encode64() |> IO.puts()
CLOAK_KEY=

# Phoenix secret key base (64+ character random string)
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=

# Phoenix host (used for URL generation)
PHX_HOST=localhost

# Playwright server port (for headless browser sync)
PLAYWRIGHT_SERVER_PORT=3000

# Pool size (number of database connections)
POOL_SIZE=5
